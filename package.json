{
  "name": "arandu",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "tailwind:build": "npx @tailwindcss/cli -i ./web/static/css/input.css -o ./web/static/css/tailwind.css --minify",
    "tailwind:build:v2": "npx @tailwindcss/cli -i ./web/static/css/input-v2.css -o ./web/static/css/tailwind-v2.css --minify",
    "tailwind:watch": "npx @tailwindcss/cli -i ./web/static/css/input.css -o ./web/static/css/tailwind.css --watch",
    "tailwind:watch:v2": "npx @tailwindcss/cli -i ./web/static/css/input-v2.css -o ./web/static/css/tailwind-v2.css --watch",
    "build:all": "npm run tailwind:build && npm run tailwind:build:v2 && go generate ./..."
  },
  "dependencies": {
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/cli": "^4.2.2",
    "autoprefixer": "^10.4.27",
    "daisyui": "^5.5.19",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2"
  }
}
