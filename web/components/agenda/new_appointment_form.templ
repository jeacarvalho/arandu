package agenda

import "fmt"

// NewAppointmentForm renders a form for creating a new appointment
templ NewAppointmentForm(data NewAppointmentFormData) {
	<div class="fixed inset-0 bg-black/50 flex items-center justify-center z-50" id="modal-backdrop">
		<div class="bg-white rounded-xl border border-neutral-200 shadow-sm w-full max-w-md mx-4 overflow-hidden">
			<!-- Header -->
			<div class="flex items-center justify-between px-6 py-4 border-b border-neutral-100 bg-neutral-50">
				<div class="flex items-center gap-3">
					<div class="w-9 h-9 rounded-lg bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-base flex-shrink-0">
						<i class="fas fa-plus"></i>
					</div>
					<h3 class="text-sm font-semibold text-neutral-700 uppercase tracking-wide">Nova Sessão</h3>
				</div>
				<button 
					hx-get="/agenda"
					hx-target="#calendar-container"
					class="text-neutral-400 hover:text-neutral-600 transition-colors"
				>
					<i class="fas fa-times"></i>
				</button>
			</div>
			
			<!-- Form -->
			<form hx-post="/agenda/appointments" hx-target="#calendar-container" hx-swap="outerHTML" class="p-6 space-y-4">
				<!-- Date -->
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Data</label>
					<input 
						type="date" 
						name="date"
						value={ data.Date.Format("2006-01-02") }
						class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
						required
					>
				</div>
				
				<!-- Patient -->
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Paciente</label>
					<select 
						name="patient_id"
						class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
						required
					>
						<option value="">Selecione um paciente...</option>
						for _, patient := range data.Patients {
							<option value={ patient.ID }>{ patient.Name }</option>
						}
					</select>
				</div>
				
				<!-- Time -->
				<div class="grid grid-cols-2 gap-4">
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Horário</label>
						<select 
							name="start_time"
							class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
							required
						>
							for hour := 8; hour < 20; hour++ {
								for _, minute := range []string{"00", "30"} {
									<option value={ fmt.Sprintf("%02d:%s", hour, minute) }>{ fmt.Sprintf("%02d:%s", hour, minute) }</option>
								}
							}
						</select>
					</div>
					<div>
						<label class="block text-sm font-medium text-neutral-700 mb-1">Duração (min)</label>
						<select 
							name="duration"
							class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
							required
						>
							<option value="30">30</option>
							<option value="50" selected>50</option>
							<option value="60">60</option>
							<option value="90">90</option>
						</select>
					</div>
				</div>
				
				<!-- Type -->
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Tipo</label>
					<select 
						name="type"
						class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
					>
						<option value="session" selected>Sessão Clínica</option>
						<option value="followup">Acompanhamento</option>
						<option value="blocked">Bloqueado</option>
					</select>
				</div>
				
				<!-- Notes -->
				<div>
					<label class="block text-sm font-medium text-neutral-700 mb-1">Observações</label>
					<textarea 
						name="notes"
						rows="3"
						class="w-full px-3 py-2 border border-neutral-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-200 focus:border-primary-500"
						placeholder="Notas adicionais..."
					></textarea>
				</div>
				
				<!-- Actions -->
				<div class="flex justify-end space-x-3 pt-4">
					<button 
						type="button"
						hx-get="/agenda"
						hx-target="#calendar-container"
						class="px-4 py-2 text-sm font-medium text-neutral-700 bg-neutral-100 hover:bg-neutral-200 rounded-lg transition-colors"
					>
						Cancelar
					</button>
					<button 
						type="submit"
						class="px-4 py-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition-colors"
					>
						Agendar
					</button>
				</div>
			</form>
		</div>
	</div>
}
