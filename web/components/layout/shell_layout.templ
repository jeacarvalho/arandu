package layout

import (
	goContext "context"
	appcontext "arandu/internal/platform/context"
	"arandu/internal/platform/helpers"
	"strings"
)

// deriveBreadcrumb retorna o breadcrumb a partir do ShellConfig.
// Se Breadcrumb está explícito, usa-o; caso contrário deriva de ActivePage.
func deriveBreadcrumb(config ShellConfig) []string {
	if len(config.Breadcrumb) > 0 {
		return config.Breadcrumb
	}
	switch config.ActivePage {
	case "dashboard":
		return []string{"Hoje"}
	case "patients":
		return []string{"Pacientes"}
	case "new-patient":
		return []string{"Pacientes", "Novo Paciente"}
	case "agenda":
		return []string{"Agenda"}
	case "patient-summary", "patient-anamnesis", "patient-history", "patient-goals":
		if config.PageTitle != "" {
			return []string{"Pacientes", config.PageTitle}
		}
		return []string{"Pacientes"}
	default:
		if config.PageTitle != "" {
			return []string{config.PageTitle}
		}
		return []string{"Arandu"}
	}
}

// userInitials extrai até 2 iniciais de um email para o avatar.
func userInitials(email string) string {
	if email == "" {
		return "?"
	}
	prefix := email
	if idx := strings.Index(email, "@"); idx > 0 {
		prefix = email[:idx]
	}
	parts := strings.FieldsFunc(prefix, func(r rune) bool {
		return r == '.' || r == '_' || r == '-'
	})
	if len(parts) >= 2 && len(parts[0]) > 0 && len(parts[1]) > 0 {
		return strings.ToUpper(string(parts[0][0])) + strings.ToUpper(string(parts[1][0]))
	}
	if len(prefix) >= 2 {
		return strings.ToUpper(prefix[:2])
	}
	return strings.ToUpper(prefix)
}

// ============================================================================
// SHELL LAYOUT - RECOMMENDED LAYOUT
// ============================================================================
//
// This is the recommended layout for all Arandu pages. It provides:
//
// 1. CSS Management: Uses content-based hash versioning (GetCSSVersionV2/GetCSSVersion)
//    for stable cache control - version only changes when CSS content changes.
//
// 2. HTMX Support: Includes hx-head="merge" support for proper head management
//    during HTMX navigation, preventing CSS desync issues.
//
// 3. Consistent Structure: Single source of truth for HTML structure, head elements,
//    and asset includes.
//
// Usage:
//
//   // With context (recommended for handlers)
//   layout.ShellWithContext(ctx, config, content)
//
//   // Direct usage
//   layout.Shell(config, content)
//
// ShellConfig fields:
//   - PageTitle: Title shown in browser tab (e.g., "Dashboard")
//   - ActivePage: Current page for highlighting nav (e.g., "dashboard", "patients")
//   - ShowSidebar: Whether to show the sidebar (default: true)
//   - SidebarVariant: "default" | "patient" (changes sidebar content)
//   - PatientID: Patient ID when SidebarVariant = "patient"
//
// ============================================================================

// ShellConfig configuração do ShellLayout
type ShellConfig struct {
	PageTitle      string
	ActivePage     string
	ShowSidebar    bool
	SidebarVariant string   // "default" | "patient"
	PatientID      string   // usado quando SidebarVariant = "patient"
	UserEmail      string
	UserName       string   // nome de exibição; se vazio usa prefixo do email
	Breadcrumb     []string // itens do breadcrumb; se vazio deriva de ActivePage
}

// ShellWithContext cria um ShellLayout com contexto e sidebar opcional
func ShellWithContext(ctx goContext.Context, config ShellConfig, content templ.Component) templ.Component {
	// Get user email from context
	userEmail, err := appcontext.GetUserEmail(ctx)
	if err != nil {
		userEmail = "user@example.com"
	}
	config.UserEmail = userEmail

	return Shell(config, content)
}

// Shell componente base de layout com Topbar, Sidebar e Main Canvas
// Uso: @Shell(config, conteúdo)
templ Shell(config ShellConfig, content templ.Component) {
	<!DOCTYPE html>
	<html lang="pt-BR">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			Arandu
			if config.PageTitle != "" {
				— { config.PageTitle }
			}
		</title>
		<!-- CSS v2 - Novo padrão Shell Layout -->
		<link href={ "/static/css/tailwind-v2.css?v=" + helpers.GetCSSVersionV2() } rel="stylesheet">
		<link href={ "/static/css/style.css?v=" + helpers.GetCSSVersion() } rel="stylesheet">
<script src="/static/js/htmx.min.js"></script>
	<!-- BFCache Fix: Must be inline and early to catch pageshow event -->
	<script>
	// Fix for browser back/forward button showing empty content
	// This runs immediately when page is restored from BFCache
	window.addEventListener('pageshow', function(event) {
		if (event.persisted) {
			console.log('[BFCache] Page restored from cache, checking content...');
			
			// Give a small delay for DOM to settle
			setTimeout(function() {
				var mainContent = document.getElementById('main-content');
				if (mainContent) {
					var html = mainContent.innerHTML.trim();
					// Check if content is effectively empty (no visible elements)
					var hasContent = mainContent.querySelector('.content-header, .sota-container, .patient-profile, .card, form, table, .clinical-content');
					
					if (!hasContent || html.length < 100) {
						console.log('[BFCache] Content missing or too small, forcing reload...');
						window.location.reload();
					} else {
						console.log('[BFCache] Content appears valid');
					}
				}
			}, 100);
		}
	});
	</script>
	<script>
	// Initialize Alpine.store('shell') before Alpine.js loads
			// This ensures the store is available when Alpine processes x-data
			document.addEventListener('alpine:init', () => {
				if (!Alpine.store('shell')) {
					Alpine.store('shell', {
						sidebarOpen: false,
						sidebarCollapsed: false,
						llmOpen: false,
						init() {
							this.sidebarOpen = false;
							this.sidebarCollapsed = localStorage.getItem('arandu-sidebar-collapsed') === 'true';
						},
						toggleSidebar()  { this.sidebarOpen = !this.sidebarOpen; },
						closeSidebar()   { this.sidebarOpen = false; },
						toggleCollapse() {
							this.sidebarCollapsed = !this.sidebarCollapsed;
							localStorage.setItem('arandu-sidebar-collapsed', this.sidebarCollapsed);
						},
						openLLM()   { this.llmOpen = true; },
						closeLLM()  { this.llmOpen = false; },
						toggleLLM() { this.llmOpen = !this.llmOpen; },
					});
				}
			});
		</script>
		<script src="https://unpkg.com/alpinejs@3.13.5/dist/cdn.min.js" defer></script>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
		<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&family=Geist:wght@300;400;500;600;700&family=Geist+Mono:wght@400;500&display=swap" rel="stylesheet">
	</head>
	<body>
		<div
			class="shell"
			x-data="Alpine.store('shell')"
			x-init="$store.shell.init()"
			@keydown.meta.j.window="$store.shell.toggleLLM()"
			@keydown.ctrl.j.window="$store.shell.toggleLLM()"
		>
			<!-- Topbar -->
			@ShellTopbar(config)

			<!-- Body -->
			<div class="shell-body">
				<!-- Mobile Sidebar Overlay -->
				<div
					@click="closeSidebar()"
					class="shell-sidebar-overlay"
					:class="sidebarOpen ? 'shell-sidebar-overlay-open' : ''"
				></div>

				<!-- Sidebar -->
				if config.ShowSidebar {
					@ShellSidebar(config)
				}

				<!-- Main Content Area -->
			<main class="shell-main">
				<!-- Scrollable Canvas -->
				<div class="shell-canvas">
					<div 
						class="shell-canvas-container"
						:class="sidebarCollapsed ? 'shell-canvas-collapsed' : 'shell-canvas-expanded'"
					>
			<div class="shell-content" id="main-content" hx-history="false">
				@content
			</div>
					</div>
				</div>
			</main>
			</div>
		</div>

		<!-- Modal Container -->
		<div id="modal-container"></div>

		<!-- Drawer Container -->
		<div id="drawer-container"></div>

		<!-- LLM Drawer (Fase 6) -->
		<div id="llm-drawer"></div>

		<!-- Toast Container -->
		<div id="toast-container"></div>

<!-- Global Scripts -->
	<script src={ "/static/js/htmx-handlers.js?v=" + helpers.GetJSVersion() }></script>
	<!-- Debug Script - Remove in production -->
	<script src="/static/js/htmx-debug.js"></script>
	</body>
	</html>
}

// ShellTopbar componente da barra superior — Sábio design
templ ShellTopbar(config ShellConfig) {
	<header class="sabio-topbar">
		<!-- Mobile Hamburger -->
		if config.ShowSidebar {
			<button
				@click="$store.shell.toggleSidebar()"
				class="shell-hamburger md:hidden"
				aria-label="Abrir menu de navegação"
				aria-controls="shell-sidebar"
			>
				<i class="fas fa-bars"></i>
			</button>
		}

		<!-- Breadcrumb -->
		<nav class="sabio-breadcrumb" aria-label="Localização">
			for i, item := range deriveBreadcrumb(config) {
				if i > 0 {
					<span class="sabio-breadcrumb-sep">›</span>
				}
				<span class="sabio-breadcrumb-item">{ item }</span>
			}
		</nav>

		<div class="sabio-topbar-spacer"></div>

		<!-- Search -->
		<div class="sabio-search-wrap">
			@ShellSearchBar()
		</div>

		<!-- LLM Button -->
		<button
			class="sabio-llm-btn"
			@click="$store.shell.toggleLLM()"
			aria-label="Abrir inteligência clínica (⌘J)"
		>
			@sabioSparklesIcon()
			<span>Arandu</span>
			<kbd class="sabio-kbd">⌘J</kbd>
		</button>

		<!-- Settings -->
		<button class="sabio-settings-btn" title="Configurações" aria-label="Configurações">
			<i class="fas fa-cog"></i>
		</button>
	</header>
}

// sabioSparklesIcon ícone sparkles inline SVG para o botão LLM
templ sabioSparklesIcon() {
	<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
		<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path>
		<path d="M5 3v4"></path>
		<path d="M19 17v4"></path>
		<path d="M3 5h4"></path>
		<path d="M17 19h4"></path>
	</svg>
}

// ShellSearchBar componente de busca na topbar
templ ShellSearchBar() {
	<div class="shell-search-container">
		<input
			id="shell-patient-search"
			type="text"
			name="q"
			placeholder="Buscar paciente..."
			hx-get="/patients/search"
			hx-trigger="keyup changed delay:350ms"
			hx-target="#shell-search-results"
			hx-indicator="#shell-search-loading"
			autocomplete="off"
			role="combobox"
			aria-label="Buscar paciente"
			aria-controls="shell-search-results"
			aria-autocomplete="list"
			aria-expanded="false"
			aria-haspopup="listbox"
			class="shell-search-input"
		/>
		<i class="fas fa-search shell-search-icon"></i>
		<span id="shell-search-loading" class="htmx-indicator absolute right-3 top-1/2 -translate-y-1/2 text-xs text-neutral-500" role="status" aria-live="polite">
			Buscando...
		</span>
		<div id="shell-search-results" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-lg border border-neutral-100 max-h-96 overflow-y-auto z-20 hidden" role="listbox" aria-label="Resultados da busca de pacientes"></div>
	</div>
}

// ShellSidebar componente da barra lateral — Sábio design
templ ShellSidebar(config ShellConfig) {
	<aside
		id="shell-sidebar"
		class="shell-sidebar"
		:class="{ 'shell-sidebar-collapsed': $store.shell.sidebarCollapsed, 'shell-sidebar-open': $store.shell.sidebarOpen }"
		aria-label="Menu de navegação"
	>
		@ShellSidebarContent(config)
	</aside>
}

// ShellSidebarContent conteúdo da sidebar — Sábio design
templ ShellSidebarContent(config ShellConfig) {
	<!-- Brand Header -->
	<div class="sabio-brand-header">
		@sabioBrandMark()
		<div class="sabio-brand-text">
			<div class="sabio-brand-name">Arandu</div>
			<div class="sabio-brand-sub">CLÍNICO</div>
		</div>
	</div>

	<!-- Navigation -->
	<nav class="sabio-nav">
		<div class="sabio-nav-section-label">MENU</div>
		if config.SidebarVariant == "patient" && config.PatientID != "" {
			@ShellPatientNavItems(config.PatientID, config.ActivePage)
		} else {
			@ShellDefaultNavItems(config.ActivePage)
		}
		<div class="sabio-nav-section-label sabio-nav-section-gap">ATALHOS</div>
		<a href="/session/new" class="sabio-nav-item">
			<span class="sabio-nav-item-icon"><i class="fas fa-plus"></i></span>
			<span class="sabio-nav-item-text">Nova sessão</span>
		</a>
		<a href="/patients/new" class="sabio-nav-item">
			<span class="sabio-nav-item-icon"><i class="fas fa-user-plus"></i></span>
			<span class="sabio-nav-item-text">Novo paciente</span>
		</a>
	</nav>

	<!-- Footer: avatar + recolher -->
	<div class="sabio-sidebar-footer">
		<div class="sabio-user-row">
			<div class="sabio-avatar" aria-hidden="true">{ userInitials(config.UserEmail) }</div>
			<div class="sabio-user-info">
				<div class="sabio-user-name">
					if config.UserName != "" {
						{ config.UserName }
					} else {
						{ config.UserEmail }
					}
				</div>
				<div class="sabio-user-meta">
					<a href="/logout" style="color:inherit;text-decoration:none;">Sair</a>
				</div>
			</div>
		</div>
		<button
			@click="$store.shell.toggleCollapse()"
			class="sabio-collapse-btn"
			aria-label="Recolher menu lateral"
		>
			<i class="fas" :class="$store.shell.sidebarCollapsed ? 'fa-chevron-right' : 'fa-chevron-left'"></i>
			<span class="sabio-collapse-btn-text">Recolher</span>
		</button>
	</div>
}

// sabioBrandMark glifo SVG identidade Sábio (folha + olho)
templ sabioBrandMark() {
	<div class="sabio-brandmark">
		<svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
			<path d="M12 3c-4 3-6 6-6 10 0 4 2 7 6 8 4-1 6-4 6-8 0-4-2-7-6-10z"></path>
			<path d="M12 7v12" opacity=".55"></path>
			<circle cx="12" cy="13" r="1.4" fill="currentColor" stroke="none"></circle>
		</svg>
	</div>
}

// ShellDefaultNavItems itens de navegação padrão
templ ShellDefaultNavItems(activePage string) {
	@ShellNavItem("/dashboard", "dashboard", activePage, "fa-chart-line", "Dashboard")
	@ShellNavItem("/patients", "patients", activePage, "fa-users", "Pacientes")
	@ShellNavItem("/agenda", "agenda", activePage, "fa-calendar", "Agenda")
}

// ShellPatientNavItems itens de navegação do contexto paciente
templ ShellPatientNavItems(patientID string, activePage string) {
	@ShellNavItem("/patients/"+patientID, "patient-summary", activePage, "fa-user-md", "Resumo")
	@ShellNavItem("/patients/"+patientID+"/anamnesis", "patient-anamnesis", activePage, "fa-history", "Anamnese")
	@ShellNavItem("/patients/"+patientID+"/history", "patient-history", activePage, "fa-file-medical", "Prontuário")
	@ShellNavItem("/patients/"+patientID+"/goals", "patient-goals", activePage, "fa-bullseye", "Plano Terapêutico")
	<div style="height:1px;background:var(--color-line);margin:8px 12px;"></div>
	<a
		href="/dashboard"
		class="sabio-nav-item"
		@click="if (window.innerWidth < 768) { $store.shell.sidebarOpen = false; }"
	>
		<span class="sabio-nav-item-icon"><i class="fas fa-arrow-left"></i></span>
		<span class="sabio-nav-item-text">Voltar ao Dashboard</span>
	</a>
}

// ShellNavItem item individual de navegação — Sábio design
templ ShellNavItem(href string, page string, activePage string, icon string, label string) {
	<a
		href={ templ.SafeURL(href) }
		class="sabio-nav-item"
		if page == activePage {
			aria-current="page"
		}
		hx-get={ href }
		hx-target="#main-content"
		hx-push-url="true"
		hx-swap="innerHTML"
		hx-head="merge"
		hx-indicator="#shell-loading"
		@click="if (window.innerWidth < 768) { $store.shell.sidebarOpen = false; }"
	>
		<span class="sabio-nav-item-icon"><i class={ "fas " + icon }></i></span>
		<span class="sabio-nav-item-text">{ label }</span>
	</a>
}

// ShellContentWrapper wrapper para conteúdos HTMX via OOB
// Usa ID único para evitar conflito com #main-content estático
templ ShellContentWrapper(content templ.Component) {
	<div id="main-content-swap" hx-swap-oob="true">
		<div class="shell-canvas-container shell-canvas-expanded">
			<div class="shell-content" id="shell-content">
				@content
			</div>
		</div>
	</div>
}

// ShellContentContainer wrapper para conteúdos HTMX sem OOB
// Usado quando HTMX replace diretamente o conteúdo
templ ShellContentContainer(content templ.Component) {
	<div 
		class="shell-canvas-container"
		style="padding-top: 80px; padding-left: 260px;"
	>
		<div class="shell-content" id="shell-content">
			@content
		</div>
	</div>
}

// ShellPageTitle componente de título de página padrão
templ ShellPageTitle(title string, subtitle string) {
	<div class="mb-6">
		<h1 class="text-2xl font-semibold text-neutral-800" data-autofocus>{ title }</h1>
		if subtitle != "" {
			<p class="mt-1 text-sm text-neutral-500">{ subtitle }</p>
		}
	</div>
}

// ShellCard componente de card padrão
templ ShellCard(title string, content templ.Component) {
	<div class="bg-white rounded-xl border border-neutral-200 shadow-sm">
		if title != "" {
			<div class="px-6 py-4 border-b border-neutral-200">
				<h2 class="text-lg font-semibold text-neutral-800">{ title }</h2>
			</div>
		}
		<div class="p-6">
			@content
		</div>
	</div>
}

// ShellLoading indicador de loading para HTMX
templ ShellLoading() {
	<div id="shell-loading" class="htmx-indicator fixed inset-0 z-[200] flex items-center justify-center bg-white/50 backdrop-blur-sm">
		<div class="flex flex-col items-center gap-3">
			<div class="w-8 h-8 border-3 border-arandu-soft border-t-arandu-primary rounded-full animate-spin"></div>
			<span class="text-sm text-neutral-600 font-medium">Carregando...</span>
		</div>
	</div>
}
