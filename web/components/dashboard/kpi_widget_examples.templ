// WidgetLoadingExample exemplo de widget em estado de loading
templ WidgetLoadingExample() {
	{{ 
		props := layout.NewWidgetProps(layout.WidgetLoading()).
			WithTitle("Carregando Dados").
			Build()
	}}
	@layout.WidgetWrapper(props)
}

// WidgetErrorExample exemplo de widget em estado de erro
templ WidgetErrorExample() {
	{{ 
		errorContent := layout.WidgetError(
			"Não foi possível carregar os dados do servidor. Verifique sua conexão.",
			"/api/retry",
		)
		
		props := layout.NewWidgetProps(errorContent).
			WithTitle("Erro").
			Build()
	}}
	@layout.WidgetWrapper(props)
}

// WidgetEmptyExample exemplo de widget vazio
templ WidgetEmptyExample() {
	{{ 
		emptyContent := layout.WidgetEmpty(
			"fa-inbox",
			"Nenhum dado encontrado",
			"Comece adicionando novos registros para visualizar os dados aqui.",
		)
		
		props := layout.NewWidgetProps(emptyContent).
			WithTitle("Histórico de Sessões").
			Build()
	}}
	@layout.WidgetWrapper(props)
}

// =============================================================================
// HELPERS
// =============================================================================

// FormatNumber formata número com separador de milhar
func FormatNumber(n int) string {
	if n < 1000 {
		return fmt.Sprintf("%d", n)
	}
	return fmt.Sprintf("%d,%03d", n/1000, n%1000)
}
