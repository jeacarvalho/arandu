package dashboard

import (
	"arandu/web/components/layout"
	"fmt"
)

// =============================================================================
// EXEMPLOS DE USO DO WIDGET WRAPPER
// =============================================================================

// KPIWidgetCard exemplo de card KPI usando WidgetWrapper
// Demonstra o uso básico do wrapper com título e conteúdo simples
templ KPIWidgetCard(title string, value string, change string, trend string) {
	{{ 
		// Cria o conteúdo do KPI
		kpiContent := KPIContent(value, change, trend)
		
		// Configura o widget usando o builder pattern
		widgetProps := layout.NewWidgetProps(kpiContent).
			WithTitle(title).
			WithSubtitle("Últimos 30 dias").
			WithHover().
			Build()
	}}
	
	@layout.WidgetWrapper(widgetProps)
}

// KPIContent conteúdo interno do card KPI
templ KPIContent(value string, change string, trend string) {
	<div class="flex items-end justify-between">
		<div>
			<p class="text-3xl font-bold text-neutral-800">{ value }</p>
			<div class="flex items-center gap-2 mt-2">
				if trend == "up" {
					<span class="text-sm font-medium text-green-600 flex items-center gap-1">
						<i class="fas fa-arrow-up"></i>
						{ change }
					</span>
				} else if trend == "down" {
					<span class="text-sm font-medium text-red-600 flex items-center gap-1">
						<i class="fas fa-arrow-down"></i>
						{ change }
					</span>
				} else {
					<span class="text-sm font-medium text-neutral-500 flex items-center gap-1">
						<i class="fas fa-minus"></i>
						{ change }
					</span>
				}
				<span class="text-sm text-neutral-400">vs mês anterior</span>
			</div>
		</div>
	</div>
}

// =============================================================================
// EXEMPLOS AVANÇADOS
// =============================================================================

// WidgetWithActionsExample exemplo de widget com ações no header
templ WidgetWithActionsExample() {
	{{ 
		// Cria as ações do header
		actions := WidgetActions()
		
		// Cria o conteúdo
		content := WidgetExampleContent()
		
		// Configura o widget com ações
		props := layout.NewWidgetProps(content).
			WithTitle("Pacientes Recentes").
			WithSubtitle("Últimas atualizações").
			WithActions(actions).
			Build()
	}}
	
	@layout.WidgetWrapper(props)
}

// WidgetActions botões de ação para o header
templ WidgetActions() {
	<div class="flex items-center gap-2">
		<button
			class="px-3 py-1.5 text-sm font-medium text-arandu-primary bg-arandu-bg rounded-lg hover:bg-arandu-soft transition-colors"
			hx-get="/patients/new"
			hx-target="#main-content"
			hx-push-url="true"
			hx-swap="innerHTML"
		>
			<i class="fas fa-plus mr-1"></i>
			Novo
		</button>
		<button
			class="p-1.5 text-neutral-400 hover:text-neutral-600 transition-colors"
			hx-get="/patients"
			hx-target="#main-content"
			hx-push-url="true"
			hx-swap="innerHTML"
			aria-label="Ver todos"
		>
			<i class="fas fa-arrow-right"></i>
		</button>
	</div>
}

// WidgetExampleContent conteúdo de exemplo
templ WidgetExampleContent() {
	<div class="space-y-3">
		@WidgetPatientRow("João Silva", "Atualizado há 2h", "active")
		@WidgetPatientRow("Maria Santos", "Atualizado há 5h", "inactive")
		@WidgetPatientRow("Carlos Oliveira", "Atualizado ontem", "active")
	</div>
}

// WidgetPatientRow linha de paciente para o widget
templ WidgetPatientRow(name string, time string, status string) {
	<div
		class="flex items-center justify-between p-3 bg-neutral-50 rounded-lg hover:bg-neutral-100 transition-colors cursor-pointer"
		hx-get="/patients/1"
		hx-target="#main-content"
		hx-push-url="true"
		hx-swap="innerHTML"
	>
		<div class="flex items-center gap-3">
			<div class="w-8 h-8 rounded-full bg-arandu-bg text-arandu-primary flex items-center justify-center font-semibold text-sm">
				{ string([]rune(name)[0]) }
			</div>
			<div>
				<p class="font-medium text-neutral-800 text-sm">{ name }</p>
				<p class="text-xs text-neutral-500">{ time }</p>
			</div>
		</div>
		if status == "active" {
			<span class="w-2 h-2 rounded-full bg-green-500"></span>
		} else {
			<span class="w-2 h-2 rounded-full bg-neutral-300"></span>
		}
	</div>
}

// =============================================================================
// EXEMPLOS COM HTMX
// =============================================================================

// WidgetWithAutoRefresh exemplo de widget com refresh automático via HTMX
templ WidgetWithAutoRefresh() {
	{{ 
		content := WidgetStatsContent()
		
	// Atributos HTMX para auto-refresh a cada 30 segundos
	htmxAttrs := templ.Attributes{
		"hx-get": "/api/stats",
		"hx-trigger": "load, every 30s",
		"hx-swap": "innerHTML",
	}
		
		props := layout.NewWidgetProps(content).
			WithTitle("Estatísticas em Tempo Real").
			WithSubtitle("Atualiza automaticamente").
			WithHTMX(htmxAttrs).
			WithID("stats-widget").
			Build()
	}}
	
	@layout.WidgetWrapper(props)
}

// WidgetStatsContent conteúdo das estatísticas
templ WidgetStatsContent() {
	<div class="grid grid-cols-2 gap-4">
		<div class="text-center p-3 bg-blue-50 rounded-lg">
			<p class="text-2xl font-bold text-blue-600">24</p>
			<p class="text-xs text-blue-600/70">Pacientes</p>
		</div>
		<div class="text-center p-3 bg-green-50 rounded-lg">
			<p class="text-2xl font-bold text-green-600">89%</p>
			<p class="text-xs text-green-600/70">Taxa de Sucesso</p>
		</div>
	</div>
}

