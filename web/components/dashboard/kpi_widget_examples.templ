// WidgetCompactExample exemplo de widget compacto
templ WidgetCompactExample() {
	@layout.WidgetCompact("Alertas Rápidos", CompactAlertsContent())
}

// CompactAlertsContent conteúdo compacto
templ CompactAlertsContent() {
	<div class="space-y-2">
		<div class="flex items-center gap-2 text-sm">
			<i class="fas fa-exclamation-circle text-amber-500"></i>
			<span class="text-neutral-700">3 sessões pendentes</span>
		</div>
		<div class="flex items-center gap-2 text-sm">
			<i class="fas fa-check-circle text-green-500"></i>
			<span class="text-neutral-700">Anamnese aprovada</span>
		</div>
	</div>
}

// WidgetNoPaddingExample exemplo de widget sem padding (full-bleed)
templ WidgetNoPaddingExample() {
	@layout.WidgetNoPadding("Mapa de Localização", MapPlaceholder())
}

// MapPlaceholder placeholder para mapa
templ MapPlaceholder() {
	<div class="bg-gradient-to-br from-arandu-bg to-arandu-soft flex items-center justify-center" style="height: 200px;">
		<div class="text-center">
			<i class="fas fa-map-marked-alt text-4xl text-arandu-primary mb-2"></i>
			<p class="text-sm text-arandu-dark font-medium">Mapa Interativo</p>
			<p class="text-xs text-arandu-dark/70">Clique para expandir</p>
		</div>
	</div>
}

// =============================================================================
// EXEMPLO COMPLETO: DASHBOARD COM WIDGETS
// =============================================================================

// DashboardWithWidgets exemplo completo de dashboard usando WidgetWrapper
// Integrado com StandardGrid
templ DashboardWithWidgets(userEmail string) {
	@layout.Shell(layout.ShellConfig{
		PageTitle:   "Dashboard",
		ActivePage:  "dashboard",
		ShowSidebar: true,
		UserEmail:   userEmail,
	}, DashboardWidgetsContent())
}

// DashboardWidgetsContent conteúdo do dashboard com widgets
templ DashboardWidgetsContent() {
	@layout.ShellPageTitle("Dashboard", "Visão geral da sua prática clínica")
	
	{{ 
		// Grid de widgets
		gridConfig := layout.NewGridConfig().
			WithID("dashboard-widgets-grid").
			AddRow(
				// Linha 1: 4 KPIs
				layout.NewGridRow().
					AddItem(layout.NewGridItem(KPIWidgetCard("Total de Pacientes", "24", "+12%", "up")).Span(1).Build()).
					AddItem(layout.NewGridItem(KPIWidgetCard("Sessões Este Mês", "48", "+8%", "up")).Span(1).Build()).
					AddItem(layout.NewGridItem(KPIWidgetCard("Taxa de Comparecimento", "92%", "+3%", "up")).Span(1).Build()).
					AddItem(layout.NewGridItem(KPIWidgetCard("Meta de Renda", "R$ 8.4k", "-2%", "down")).Span(1).Build()).
					Build(),
			).
			AddRow(
				// Linha 2: Widget com ações + Widget compacto
				layout.NewGridRow().
					AddItem(layout.NewGridItem(WidgetWithActionsExample()).Span(3).Build()).
					AddItem(layout.NewGridItem(WidgetCompactExample()).Span(1).Build()).
					Build(),
			).
			AddRow(
				// Linha 3: Widget com auto-refresh (largura total)
				layout.NewGridRow().
					AddItem(layout.NewGridItem(WidgetWithAutoRefresh()).Span(2).Build()).
					AddItem(layout.NewGridItem(WidgetNoPaddingExample()).Span(2).Build()).
					Build(),
			).
			Build()
	}}
	
	@layout.StandardGrid(gridConfig)
}

